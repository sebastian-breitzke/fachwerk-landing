---
import Base from '../../layouts/Base.astro';
import IndustryTabs from '../../components/IndustryTabs.astro';
import NordWare from '../../components/mockups/NordWare.astro';
import StahlbergWerke from '../../components/mockups/StahlbergWerke.astro';
import HartmannElektro from '../../components/mockups/HartmannElektro.astro';
import Gruenfeld from '../../components/mockups/Gruenfeld.astro';
import Dachstein from '../../components/mockups/Dachstein.astro';
---

<Base title="Fachwerk — Beispiele" currentPage="beispiele">
  <IndustryTabs />

  <div class="beispiele-intro">
    <h1>Erlebe Fachwerk.</h1>
    <p>Jede Industrie hat andere Prozesse, andere Systeme, andere Anforderungen. Fachwerk passt sich an — hier siehst du wie.</p>
  </div>

  <!-- E-Commerce -->
  <div class="industry-panel active" data-panel="ecommerce">
    <section class="example">
      <span class="section-label">// Flow</span>
      <h2 class="section-headline">Retouren-Quote steigt?<br>Ads stoppen automatisch.</h2>

      <p class="example-intro">Dein Shop meldet: <em>die Retouren-Quote bei einem Produkt steigt.</em> Bisher merkt das erst jemand, wenn die Marge längst im Keller ist — und die Werbeausgaben weiter laufen.</p>

      <p class="example-intro">Fachwerk erkennt den Trend, <em>pausiert automatisch die Kampagnen</em> bei Facebook und Instagram für das Produkt. Einkauf bekommt eine Benachrichtigung mit Kontext. Egal ob Shopify, Amazon Seller Central oder dein WaWi-System — Fachwerk spricht die Standard-APIs.</p>

      <p class="example-intro">Wenn es hilft, analysiert die AI die Retourengründe aus Bewertungen und schlägt eine Listing-Anpassung vor. <em>Nicht weil sie immer muss — sondern weil es hier Sinn ergibt.</em></p>

      <div class="terminal-quote" data-label="AUTOMATISIERUNG — KAMPAGNEN-STEUERUNG"><strong>Produkt SKU-4820</strong> · Retouren-Rate 18% (&#8593; von 6%)

<span class="tq-label">Aktion:</span>   Meta Ads pausiert (3 Kampagnen).
<span class="tq-label">Grund:</span>    Retourenquote über Schwellwert.
<span class="tq-label">Einkauf:</span>  Benachrichtigt, Ticket erstellt.</div>

      <div class="terminal-quote" data-label="AI-ANALYSE — OPTIONAL"><strong>Retourengründe</strong> · SKU-4820 · letzte 30 Tage

<span class="tq-label">Top-Grund:</span>  "Farbe weicht vom Bild ab" (63%)
<span class="tq-label">Empfehlung:</span> Produktfotos aktualisieren.
<span class="tq-label">Priorität:</span>  Hoch — Listing aktiv in 2 Märkten.</div>

      <p class="punchline">Keine verbrannten Werbebudgets. Keine Überraschungen bei der Monatsabrechnung. Fachwerk handelt, bevor der Schaden wächst.</p>
    </section>

    <div class="divider"></div>

    <section class="example">
      <span class="section-label">// Oberfläche</span>
      <h2 class="section-headline">Retouren-Cockpit —<br>nicht nur Zahlen</h2>

      <p class="example-intro">Retouren-Reports hat jeder. Aber <em>was machst du damit?</em> Tab wechseln, ins Ad-Tool, Kampagne suchen, pausieren, zurück, nächstes Produkt. Fachwerk baut dir eine Oberfläche mit genau den Aktionen, die du in diesem Moment brauchst — <em>maßgeschneidert für deinen Prozess, nicht für den Durchschnitt.</em></p>

      <NordWare />

      <p class="punchline">Jede Aktion ist ein Klick — keine Navigation, kein Systemwechsel. Die Aktionen sind nicht generisch, sondern exakt auf deinen Workflow zugeschnitten.</p>
    </section>

    <section class="logimat" style="border-top: none;">
      <h2 class="logimat-headline">Dein Shop verliert Geld an manuelle Prozesse?</h2>
      <a href="/de/kontakt/" class="cta-button">30 Minuten für E-Commerce</a>
    </section>
  </div>

  <!-- Fertigung -->
  <div class="industry-panel" data-panel="fertigung">
    <section class="example">
      <span class="section-label">// Flow</span>
      <h2 class="section-headline">Temperaturabweichung?<br>Charge gesperrt, ERP informiert.</h2>

      <p class="example-intro">Ein Sensor an Linie 3 meldet eine Abweichung. <em>Bisher sieht das erst die Qualitätssicherung — Stunden später.</em> Die Charge ist längst weiterverarbeitet, Rückverfolgung wird zum Projekt.</p>

      <p class="example-intro">Fachwerk läuft direkt im Werk — <em>lokal, im Firmennetz, hinter der Firewall.</em> Es spricht mit Maschinen und SPS-Steuerungen, auch über ältere Protokolle wie Raw TCP/IP oder Modbus. Keine Cloud-Abhängigkeit, keine Latenz.</p>

      <p class="example-intro">Fachwerk korreliert den Sensorwert mit der letzten Chargenprüfung, <em>sperrt die Charge automatisch im ERP</em> — ob SAP, proALPHA oder euer Branchen-ERP — und benachrichtigt den Schichtleiter. Wenn ein Muster erkennbar ist, liefert die AI den Kontext: <em>"Abweichung tritt seit dem Werkzeugwechsel in KW 12 auf."</em> Nicht geraten — aus den Daten abgeleitet.</p>

      <div class="terminal-quote" data-label="AUTOMATISIERUNG — QUALITÄTSSICHERUNG"><strong>Linie 3</strong> · Temperaturabweichung erkannt

<span class="tq-label">Messwert:</span>  187°C (Soll: 175°C ± 5°C)
<span class="tq-label">Charge:</span>    CH-20260402-L3 gesperrt.
<span class="tq-label">ERP:</span>       Sperrung eingetragen, QS informiert.</div>

      <div class="terminal-quote" data-label="AI-ANALYSE — OPTIONAL"><strong>Musteranalyse</strong> · Linie 3 · letzte 6 Wochen

<span class="tq-label">Muster:</span>     Abweichung seit KW 12 (Werkzeugwechsel).
<span class="tq-label">Korrelation:</span> Neues Werkzeug + hohe Taktrate.
<span class="tq-label">Empfehlung:</span>  Werkzeugkalibrierung prüfen.</div>

      <p class="punchline">Kein stiller Qualitätsverlust. Keine Rückverfolgung über drei Schichten. Fachwerk greift ein, bevor die Charge das Werk verlässt.</p>
    </section>

    <div class="divider"></div>

    <section class="example">
      <span class="section-label">// Oberfläche</span>
      <h2 class="section-headline">Schichtleiter-Dashboard —<br>am Band, nicht im Büro</h2>

      <p class="example-intro">Der Schichtleiter braucht kein BI-Tool mit Filterkaskaden. Er braucht auf dem Tablet am Band: <em>was läuft, was steht, wo muss ich entscheiden.</em> Und er braucht Aktionen, die genau zu seinem Werk passen — <em>Charge freigeben, Wartung verschieben, QS eskalieren.</em> Keine generischen Buttons, sondern seine Prozesse.</p>

      <StahlbergWerke />

      <p class="punchline">Jede Aktion greift direkt ins ERP, in die SPS, ins QS-System — ein Klick, kein Umweg. Auditierbar, nachvollziehbar, revisionssicher. Maßgeschneidert für dieses Werk, diese Schicht, diesen Schichtleiter.</p>
    </section>

    <section class="logimat" style="border-top: none;">
      <h2 class="logimat-headline">Deine Maschinen reden nicht mit deinem ERP?</h2>
      <a href="/de/kontakt/" class="cta-button">30 Minuten für Fertigung</a>
    </section>
  </div>

  <!-- Handel -->
  <div class="industry-panel" data-panel="handel">
    <section class="example">
      <span class="section-label">// Flow</span>
      <h2 class="section-headline">40 Lieferanten, 40 Formate?<br>Ein System.</h2>

      <p class="example-intro">Jede Woche kommen tausende Artikel-Updates von Dutzenden Lieferanten — <em>als CSV, Excel, PDF, EDI, oder per E-Mail.</em> Verschiedene Formate, verschiedene Strukturen, verschiedene Logiken. Bisher tippt jemand das manuell ins ERP.</p>

      <p class="example-intro">Fachwerk normalisiert die Daten automatisch, <em>gleicht Preise, Verfügbarkeiten und Artikelstammdaten mit eurem ERP ab</em> und meldet Konflikte mit Kontext. Egal ob SAP, proALPHA oder eure Branchensoftware — Fachwerk spricht die Standard-APIs und Importformate.</p>

      <p class="example-intro">Wenn Muster erkennbar sind, liefert die AI den Kontext: <em>"Lieferant X hat seit 3 Monaten systematisch höhere Frachtkosten."</em> Nicht geraten — aus den Daten.</p>

      <div class="terminal-quote" data-label="AUTOMATISIERUNG — LIEFERANTEN-SYNC"><strong>Wöchentlicher Import</strong> · 40 Lieferanten · 3.247 Artikel

<span class="tq-label">Verarbeitet:</span>  3.189 Artikel automatisch übernommen.
<span class="tq-label">Konflikte:</span>    47 Preisabweichungen, 11 neue Artikel.
<span class="tq-label">Aktion:</span>       Konflikte an Einkauf, neue Artikel zur Freigabe.</div>

      <div class="terminal-quote" data-label="AI-ANALYSE — OPTIONAL"><strong>Musteranalyse</strong> · Lieferant Schneider Electric · 6 Monate

<span class="tq-label">Muster:</span>      Preiserhöhung in 4 von 6 Lieferungen (Ø +3,2%).
<span class="tq-label">Kategorie:</span>   Sicherungstechnik, Leitungsschutzschalter.
<span class="tq-label">Empfehlung:</span>  Konditionsgespräch vor nächster Rahmenvereinbarung.</div>

      <p class="punchline">Kein manuelles Abtippen mehr. Kein "haben wir den Preis schon aktualisiert?". Fachwerk synchronisiert — du entscheidest nur noch bei Ausnahmen.</p>
    </section>

    <div class="divider"></div>

    <section class="example">
      <span class="section-label">// Oberfläche</span>
      <h2 class="section-headline">Artikelpflege —<br>Überblick statt Einzelkampf</h2>

      <p class="example-intro">Dein Einkauf braucht keine Liste mit 3.000 Änderungen zum Durchscrollen. Er braucht: <em>was ist neu, was weicht ab, was muss ich entscheiden.</em> Und er braucht Aktionen die zu seinem Prozess passen — <em>Preis übernehmen, Lieferant eskalieren, Artikel freigeben.</em> Nicht generische Buttons, sondern sein Workflow.</p>

      <HartmannElektro />

      <p class="punchline">Jede Aktion greift direkt ins ERP, in die Lieferantenkommunikation, in die Preispflege — ein Klick, kein Systemwechsel. Gebaut für diesen Großhandel, nicht für den Durchschnitt.</p>
    </section>

    <section class="logimat" style="border-top: none;">
      <h2 class="logimat-headline">Dein bester Mitarbeiter macht nur noch Datenpflege?</h2>
      <a href="/de/kontakt/" class="cta-button">30 Minuten für Handel</a>
    </section>
  </div>

  <!-- Finanzen -->
  <div class="industry-panel" data-panel="finanzen">
    <section class="example">
      <span class="section-label">// Flow</span>
      <h2 class="section-headline">Rechnung passt nicht?<br>Klärungsfall mit Kontext.</h2>

      <p class="example-intro">Eingangsrechnung kommt per Mail. <em>Bisher: ausdrucken, Ordner raus, Bestellung suchen, Lieferschein suchen, vergleichen.</em> Bei Abweichungen beginnt das Telefonieren.</p>

      <p class="example-intro">Fachwerk gleicht automatisch mit Bestellung und Lieferschein ab — gegen DATEV, SAP oder eure Buchhaltungslösung, über Standard-APIs und Importformate. <em>Passt alles — Freigabe läuft automatisch.</em> Abweichung? Klärungsfall mit vollständigem Kontext an den Sachbearbeiter.</p>

      <p class="example-intro">Bei wiederkehrenden Abweichungen erkennt die AI das Muster: <em>"Lieferant X rechnet seit drei Monaten Frachtkosten ab, die nicht vereinbart sind."</em> Nicht geraten — aus den Daten.</p>

      <div class="terminal-quote" data-label="AUTOMATISIERUNG — RECHNUNGSABGLEICH"><strong>Rechnung #R-20260328</strong> · Lieferant Müller GmbH

<span class="tq-label">Bestellung:</span>  PO-8821 · Match.
<span class="tq-label">Lieferschein:</span> LS-4455 · Match.
<span class="tq-label">Betrag:</span>      Abweichung +142,00 € (Frachtkosten).
<span class="tq-label">Aktion:</span>      Klärungsfall erstellt, Sachbearbeiter informiert.</div>

      <div class="terminal-quote" data-label="AI-ANALYSE — OPTIONAL"><strong>Musteranalyse</strong> · Lieferant Müller GmbH · 6 Monate

<span class="tq-label">Muster:</span>      Frachtkosten-Aufschlag in 4 von 6 Rechnungen.
<span class="tq-label">Summe:</span>       568,00 € nicht vereinbarte Mehrkosten.
<span class="tq-label">Empfehlung:</span>  Konditionen mit Lieferant klären.</div>

      <p class="punchline">Kein manueller Abgleich. Keine vergessenen Abweichungen. Fachwerk prüft, was passt — und liefert Kontext, wo es nicht passt.</p>
    </section>

    <div class="divider"></div>

    <section class="example">
      <span class="section-label">// Oberfläche</span>
      <h2 class="section-headline">Freigabe-Board —<br>ein Klick statt drei Systeme</h2>

      <p class="example-intro">Der Sachbearbeiter braucht keine Rechnungsliste zum Durchscrollen. Er braucht: <em>was ist offen, was weicht ab, was kann ich freigeben.</em> Und er braucht Aktionen, die zu seinem Freigabeprozess passen — <em>Rechnung freigeben, Lieferschein nachfordern, Klärungsfall an den Einkauf.</em> Nicht generische Buttons, sondern exakt sein Workflow.</p>

      <Gruenfeld />

      <p class="punchline">Jede Aktion greift direkt ins ERP, in die Buchhaltung, in den Einkauf — ein Klick, kein Systemwechsel. GoBD-konform. Jede Aktion nachvollziehbar, jeder Abgleich dokumentiert. Gebaut für diesen Prozess, nicht für den Durchschnitt.</p>
    </section>

    <section class="logimat" style="border-top: none;">
      <h2 class="logimat-headline">Rechnungen stapeln sich, Monatsabschluss dauert?</h2>
      <a href="/de/kontakt/" class="cta-button">30 Minuten für Finanzen</a>
    </section>
  </div>

  <!-- Immobilien -->
  <div class="industry-panel" data-panel="immobilien">
    <section class="example">
      <span class="section-label">// Flow</span>
      <h2 class="section-headline">Nebenkostenabrechnung<br>in Tagen statt Monaten.</h2>

      <p class="example-intro">Nebenkostenabrechnungen dauern Monate — <em>weil Daten aus 5 verschiedenen Quellen zusammengesucht werden müssen.</em> Versorger-Rechnungen, Verbrauchsdaten, Umlageschlüssel, Mieterwechsel — alles manuell zusammenführen, prüfen, berechnen.</p>

      <p class="example-intro">Fachwerk holt die Daten automatisch aus Hausverwaltungssoftware, Versorgerportalen und Zählerständen, <em>berechnet die Umlagen, erkennt Ausreißer</em> und erstellt die Abrechnungsentwürfe. Egal ob Wodis, iX-Haus oder Domus — Fachwerk spricht die vorhandenen Schnittstellen.</p>

      <p class="example-intro">Bei Auffälligkeiten prüft die AI den Kontext: <em>"Heizkosten Objekt Birkenweg 7 sind 40% über Vorjahr — Ursache: defekte Thermostatventile seit Oktober."</em> Keine Rückfrage an den Versorger nötig, die Erklärung liegt in den Daten.</p>

      <div class="terminal-quote" data-label="AUTOMATISIERUNG — NEBENKOSTENABRECHNUNG"><strong>Objekt Rosenstraße 14</strong> · 24 Einheiten · Abrechnungsjahr 2025

<span class="tq-label">Datenquellen:</span>  Stadtwerke, ISTA, Wodis · alle synchronisiert.
<span class="tq-label">Status:</span>        22 von 24 Abrechnungen erstellt.
<span class="tq-label">Ausreißer:</span>     2 Einheiten mit Verbrauchsabweichung >30%.
<span class="tq-label">Aktion:</span>        Entwürfe zur Freigabe, Ausreißer markiert.</div>

      <div class="terminal-quote" data-label="AI-ANALYSE — OPTIONAL"><strong>Ausreißer-Analyse</strong> · Whg. 3 OG links

<span class="tq-label">Abweichung:</span>   Heizkosten +42% ggü. Vorjahr.
<span class="tq-label">Ursache:</span>      Thermostatventile defekt seit Okt. 2025 (Schadensmeldung #847).
<span class="tq-label">Empfehlung:</span>   Kosten teilweise auf Instandhaltung buchen, Mieter informieren.</div>

      <p class="punchline">Keine drei Monate Nebenkostenabrechnung mehr. Fachwerk sammelt die Daten, rechnet, markiert Auffälligkeiten — du gibst nur noch frei.</p>
    </section>

    <div class="divider"></div>

    <section class="example">
      <span class="section-label">// Oberfläche</span>
      <h2 class="section-headline">Objektmanager —<br>alle Vorgänge, ein Blick</h2>

      <p class="example-intro">Der Verwalter braucht keine Excelliste pro Objekt. Er braucht: <em>was ist offen, wer kümmert sich, wo muss ich eingreifen.</em> Und er braucht Aktionen, die zu seiner Verwaltung passen — <em>Handwerker beauftragen, Mieter informieren, Versicherung melden.</em> Nicht ein Standard-Tool für alle, sondern seine Prozesse, seine Objekte, seine Abläufe.</p>

      <Dachstein />

      <p class="punchline">Jede Aktion greift direkt in die Hausverwaltungssoftware, ins Handwerker-Portal, in die Mieter-Kommunikation — ein Klick, kein Umweg. Von der Nebenkostenabrechnung bis zur Schadensmeldung, gebaut für diese Verwaltung.</p>
    </section>

    <section class="logimat" style="border-top: none;">
      <h2 class="logimat-headline">Nebenkostenabrechnung dauert 3 Monate?</h2>
      <a href="/de/kontakt/" class="cta-button">30 Minuten für Immobilien</a>
    </section>
  </div>

  <div class="divider"></div>

  <script>
    // Industry switcher
    function switchIndustry(industry: string) {
      document.querySelectorAll('.industry-pill').forEach(p =>
        p.classList.toggle('active', (p as HTMLElement).dataset.industry === industry)
      );
      document.querySelectorAll('.industry-panel').forEach(panel =>
        panel.classList.toggle('active', (panel as HTMLElement).dataset.panel === industry)
      );
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    document.querySelectorAll('.industry-pills').forEach(container => {
      container.addEventListener('click', (e) => {
        const pill = (e.target as HTMLElement).closest('.industry-pill') as HTMLElement | null;
        if (!pill) return;
        switchIndustry(pill.dataset.industry!);
      });
    });
  </script>
</Base>

<style is:global>
  .beispiele-intro {
    padding: 4.5rem 8vw 1rem;
    max-width: 40rem;
  }
  .beispiele-intro h1 {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: clamp(1.6rem, 4vw, 3rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.15;
    color: var(--fg);
    margin-bottom: 1.5rem;
  }
  .beispiele-intro p {
    font-size: 1.05rem;
    color: var(--muted-text);
    line-height: 1.8;
  }
</style>
