---
import Base from '../../layouts/Base.astro';
import MiniCta from '../../components/MiniCta.astro';
---
<Base title="Fachwerk — Preise" currentPage="preise">

<!-- HERO -->
<section class="pricing-hero">
  <h1 class="pricing-headline">Automatisierung,<br>die sich rechnet.</h1>
  <p class="pricing-sub">Drei Pakete. Ein Prinzip: Du zahlst für Ergebnisse, nicht für Features.</p>
</section>

<!-- PACKAGE CARDS -->
<div class="pricing-grid reveal">

  <!-- Betrieb -->
  <div class="pricing-card">
    <div class="pricing-card-name">Betrieb</div>
    <div class="pricing-card-price">2.500 &euro; <span>/ Monat</span></div>
    <p class="pricing-card-desc">Es läuft. Wenn nicht, kümmern wir uns — du merkst nichts.</p>
    <ul class="pricing-card-list">
      <li>Bis zu 3 aktive produktive Automationen</li>
      <li>Bis 5.000 Geschäftsfälle/Monat</li>
      <li>Run-Diagnosen und Bugfixes durch Fachwerk</li>
      <li>Monatlicher Statusreport</li>
      <li>Support: innerhalb 24h (dt. Geschäftszeiten)</li>
    </ul>
    <p class="pricing-card-typical">Typisch für: Teams mit kritischen Prozessen, die zuverlässig laufen müssen.</p>
    <a href="/de/kontakt/" class="cta-button">Betrieb anfragen</a>
  </div>

  <!-- Betrieb + Werkstatt -->
  <div class="pricing-card featured">
    <div class="pricing-card-name">Betrieb + Werkstatt</div>
    <div class="pricing-card-price">4.500 &euro; <span>/ Monat</span></div>
    <p class="pricing-card-desc">Diagnosen, Ad-hoc-Analysen und kleine Änderungen selbst anstossen.</p>
    <ul class="pricing-card-list">
      <li>Alles aus Betrieb</li>
      <li>3 Basic User mit Werkstatt-Zugang</li>
      <li>50 Werkstatt-Vorgänge/Monat (Diagnosen, kleine Änderungen)</li>
      <li>Freigabe-Workflow für Änderungen</li>
      <li>Support: innerhalb 8h (dt. Geschäftszeiten)</li>
    </ul>
    <p class="pricing-card-typical">Typisch für: IT-affine Teams, die Diagnosen und kleine Änderungen selbst anstossen wollen.</p>
    <a href="/de/kontakt/" class="cta-button">Werkstatt kennenlernen</a>
  </div>

  <!-- Betrieb + Builder -->
  <div class="pricing-card">
    <div class="pricing-card-name">Betrieb + Builder</div>
    <div class="pricing-card-price">7.500 &euro; <span>/ Monat</span></div>
    <p class="pricing-card-desc">Eigene Power User befähigen und selbst bauen.</p>
    <ul class="pricing-card-list">
      <li>Alles aus Werkstatt</li>
      <li>2 Power User mit vollen Build-Rechten</li>
      <li>Volle Build-Phase (Flow-Planung, Implementierung)</li>
      <li>4 Advisory-Stunden/Monat</li>
      <li>Support: innerhalb 4h (dt. Geschäftszeiten)</li>
    </ul>
    <p class="pricing-card-typical">Typisch für: Unternehmen mit interner IT, die Fachwerk als Plattform nutzen.</p>
    <a href="/de/kontakt/" class="cta-button">Builder-Paket besprechen</a>
  </div>

</div>

<!-- TRUST LINE -->
<p class="pricing-trust">SAP, DATEV, Salesforce, Shopify — Fachwerk spricht jede Standard-API. Deine Daten bleiben bei dir. On-Premise möglich. DSGVO-konform.</p>

<!-- LAUNCH COSTS -->
<section class="pricing-note reveal">
  <h3>Einstieg</h3>
  <p>Jedes Paket beginnt mit einem Launch-Projekt: Discovery, Build, Handover.</p>
  <ul>
    <li>Betrieb: Launch ab 12.000 €</li>
    <li>Werkstatt: Launch ab 25.000 € (inkl. Schulung und Playbooks)</li>
    <li>Builder: Launch ab 40.000 € (inkl. Deep Enablement und Governance-Setup)</li>
  </ul>
  <p style="margin-top: 1rem;"><strong>Für Erstkunden:</strong> Launch im Jahresvertrag integrierbar — kein separates Budget nötig. Beispiel: Betrieb all-in ab 3.500 €/Monat.</p>
</section>

<!-- IMMER DABEI -->
<section class="pricing-note reveal">
  <h3>Immer dabei</h3>
  <p>In jedem Paket enthalten — ohne Aufpreis:</p>
  <ul>
    <li>Deterministische Runtime mit Audit-Trail</li>
    <li>Versionierte Releases, Secrets Management, Monitoring</li>
    <li>On-Premise, Cloud oder Hybrid</li>
    <li>Definierter Launch mit Discovery, Build und Handover</li>
  </ul>
</section>

<!-- ADD-ONS -->
<div class="addons-wrap reveal">
  <h3>Add-ons</h3>
  <table class="addons-table">
    <thead>
      <tr>
        <th>Add-on</th>
        <th>Beschreibung</th>
        <th>Preis</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Volumenband M</td>
        <td>5.001–15.000 Geschäftsfälle/Monat</td>
        <td>+500 &euro;/Monat</td>
      </tr>
      <tr>
        <td>Volumenband L</td>
        <td>15.001–50.000 Geschäftsfälle/Monat</td>
        <td>+1.500 &euro;/Monat</td>
      </tr>
      <tr>
        <td>Volumenband XL</td>
        <td>50.001+ Geschäftsfälle/Monat</td>
        <td>individuell</td>
      </tr>
      <tr>
        <td>Mehr Automationen</td>
        <td>4–7 aktive Automationen</td>
        <td>+1.000 &euro;/Monat</td>
      </tr>
      <tr>
        <td>Mehr Automationen</td>
        <td>8–15 aktive Automationen</td>
        <td>+2.500 &euro;/Monat</td>
      </tr>
      <tr>
        <td>Zusätzliche Basic User</td>
        <td>Ab dem 4. User (Werkstatt/Builder)</td>
        <td>+200 &euro;/User/Monat</td>
      </tr>
      <tr>
        <td>Zusätzliche Power User</td>
        <td>Benannter Power User (Builder)</td>
        <td>+600 &euro;/User/Monat</td>
      </tr>
      <tr>
        <td>Advisory Retainer</td>
        <td>8 Stunden/Monat</td>
        <td>+1.800 &euro;/Monat</td>
      </tr>
      <tr>
        <td>Advisory Retainer</td>
        <td>16 Stunden/Monat</td>
        <td>+3.200 &euro;/Monat</td>
      </tr>
      <tr>
        <td>Werkstatt-Vorgänge</td>
        <td>Credit-Pack à 25 Vorgänge</td>
        <td>500 &euro; einmalig</td>
      </tr>
      <tr>
        <td>Change Request</td>
        <td>Neue Integration, neuer Prozess, grösserer Umbau</td>
        <td>2.000–10.000 &euro;</td>
      </tr>
    </tbody>
  </table>
</div>

<!-- PRICING PHILOSOPHY -->
<section class="pricing-philosophy reveal">
  <h3>Preislogik</h3>
  <p>Abgerechnet wird nach Geschäftsfällen, nicht nach Tokens oder Features. Ein Geschäftsfall ist ein abgeschlossener Prozesslauf — ein verarbeitetes Dokument, ein Sync-Lauf, eine automatisierte Entscheidung.</p>
  <p>Kein Feature-Gating. Der Unterschied zwischen den Paketen ist Zugang und Befähigung, nicht Funktionalität. Und Volumen-Überschreitungen werden immer vorab kommuniziert, nie stillschweigend aktiviert.</p>
</section>

<!-- FOOTER NOTE -->
<p class="pricing-footer-note">Alle Preise zzgl. USt. Launch-Projekt wird separat kalkuliert.</p>

<!-- MINI CTA -->
<MiniCta
  headline="Bereit für den nächsten Schritt?"
  buttonText="Kontakt aufnehmen"
  href="/de/kontakt/"
/>

<style>
  /* ═══════════════════════════════════════════════
     PRICING — HERO
     ═══════════════════════════════════════════════ */
  .pricing-hero {
    padding: 10rem 8vw 4rem;
    max-width: 52rem;
  }

  .pricing-headline {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: clamp(1.6rem, 4vw, 3rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.15;
    color: var(--fg);
    margin-bottom: 1.5rem;
  }

  .pricing-sub {
    font-size: 1.05rem;
    color: var(--muted-text);
    line-height: 1.8;
    max-width: 40rem;
  }

  /* ═══════════════════════════════════════════════
     PRICING — CARDS
     ═══════════════════════════════════════════════ */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    padding: 2rem 8vw 4rem;
    max-width: 72rem;
  }

  .pricing-card {
    border: 2px solid var(--border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .pricing-card.featured {
    border-color: var(--primary);
    box-shadow: 4px 4px 0 rgba(42, 144, 128, 0.15);
  }

  .pricing-card-name {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--primary);
  }

  .pricing-card-price {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 2rem;
    color: var(--fg);
  }

  .pricing-card-price span {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--muted-text);
  }

  .pricing-card-desc {
    font-size: 0.9rem;
    color: var(--muted-text);
    line-height: 1.7;
  }

  .pricing-card-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pricing-card-list li {
    font-size: 0.85rem;
    color: var(--fg);
    padding-left: 1.2rem;
    position: relative;
  }

  .pricing-card-list li::before {
    content: '\2014';
    position: absolute;
    left: 0;
    color: var(--primary);
    font-weight: 600;
  }

  .pricing-card-typical {
    font-size: 0.8rem;
    color: var(--muted-text);
    font-style: italic;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    margin-top: auto;
  }

  .pricing-trust {
    padding: 0 8vw;
    font-size: 0.85rem;
    color: var(--muted-text);
    line-height: 1.8;
    margin-top: -1rem;
  }

  /* ═══════════════════════════════════════════════
     PRICING — NOTES & SECTIONS
     ═══════════════════════════════════════════════ */
  .pricing-note {
    padding: 4rem 8vw;
    max-width: 52rem;
  }

  .pricing-note h3 {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg);
    margin-bottom: 1.5rem;
  }

  .pricing-note p,
  .pricing-note li {
    font-size: 0.95rem;
    color: var(--muted-text);
    line-height: 1.8;
  }

  .pricing-note ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .pricing-note ul li {
    padding-left: 1.2rem;
    position: relative;
  }

  .pricing-note ul li::before {
    content: '\2014';
    position: absolute;
    left: 0;
    color: var(--primary);
    font-weight: 600;
  }

  /* ═══════════════════════════════════════════════
     PRICING — ADD-ONS TABLE
     ═══════════════════════════════════════════════ */
  .addons-wrap {
    padding: 0 8vw 4rem;
  }

  .addons-wrap h3 {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg);
    margin-bottom: 1.5rem;
  }

  .addons-table {
    width: 100%;
    max-width: 52rem;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .addons-table th {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted-text);
    text-align: left;
    padding: 0.5rem 1rem;
    border-bottom: 2px solid var(--border);
  }

  .addons-table td {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--border);
    color: var(--fg);
  }

  .addons-table td:last-child {
    font-family: var(--font-mono);
    font-weight: 600;
    white-space: nowrap;
  }

  /* ═══════════════════════════════════════════════
     PRICING — PHILOSOPHY
     ═══════════════════════════════════════════════ */
  .pricing-philosophy {
    padding: 4rem 8vw;
    max-width: 52rem;
    border-top: 2px solid var(--border);
  }

  .pricing-philosophy h3 {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg);
    margin-bottom: 1.5rem;
  }

  .pricing-philosophy p {
    font-size: 0.95rem;
    color: var(--muted-text);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  /* ═══════════════════════════════════════════════
     PRICING — FOOTER NOTE
     ═══════════════════════════════════════════════ */
  .pricing-footer-note {
    padding: 0 8vw 3rem;
    font-size: 0.75rem;
    color: var(--muted-text);
    font-style: italic;
  }

  /* ═══════════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════════ */
  @media (max-width: 900px) {
    .pricing-grid {
      grid-template-columns: 1fr;
      max-width: 28rem;
    }
    .pricing-hero {
      padding: 8rem 6vw 3rem;
    }
    .pricing-note {
      padding: 3rem 6vw;
    }
    .addons-wrap {
      padding: 0 6vw 3rem;
    }
    .addons-table {
      width: 100%;
    }
    .pricing-philosophy {
      padding: 3rem 6vw;
    }
    .pricing-footer-note {
      padding: 0 6vw 2rem;
    }
  }
</style>
</Base>
