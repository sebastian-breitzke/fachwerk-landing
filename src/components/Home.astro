---
import type { HomeT } from '../i18n/home-de';
import { Image, getImage } from 'astro:assets';
import flowsThumb from '../assets/hero/flows.jpg';
import flowsFull from '../assets/hero/flows-full.jpg';
import flowThumb from '../assets/hero/flow.jpg';
import flowFull from '../assets/hero/flow-full.jpg';
import analyse1Thumb from '../assets/hero/freie-analyse-1.jpg';
import analyse1Full from '../assets/hero/freie-analyse-1-full.jpg';
import analyse2Thumb from '../assets/hero/freie-analyse-2.jpg';
import analyse2Full from '../assets/hero/freie-analyse-2-full.jpg';
import appsThumb from '../assets/hero/apps.jpg';
import appsFull from '../assets/hero/apps-full.jpg';
import outreachThumb from '../assets/hero/outreach-mail.jpg';
import outreachFull from '../assets/hero/outreach-mail-full.jpg';
import daten1Thumb from '../assets/hero/daten-1.jpg';
import daten1Full from '../assets/hero/daten-1-full.jpg';
import daten2Thumb from '../assets/hero/daten-2.jpg';
import daten2Full from '../assets/hero/daten-2-full.jpg';
import '../styles/home.css';

const rawSlides = {
  flows: { thumb: flowsThumb, full: flowsFull },
  flow: { thumb: flowThumb, full: flowFull },
  'freie-analyse-1': { thumb: analyse1Thumb, full: analyse1Full },
  'freie-analyse-2': { thumb: analyse2Thumb, full: analyse2Full },
  apps: { thumb: appsThumb, full: appsFull },
  'outreach-mail': { thumb: outreachThumb, full: outreachFull },
  'daten-1': { thumb: daten1Thumb, full: daten1Full },
  'daten-2': { thumb: daten2Thumb, full: daten2Full },
};

// Build WebP URLs for the full-size lightbox variant at build time
const SLIDES: Record<string, { thumb: typeof flowsThumb; fullUrl: string }> = {};
for (const [id, imgs] of Object.entries(rawSlides)) {
  const processed = await getImage({ src: imgs.full, format: 'webp', width: 3200, quality: 86 });
  SLIDES[id] = { thumb: imgs.thumb, fullUrl: processed.src };
}

interface Props {
  t: HomeT;
  locale: 'de' | 'en' | 'es';
}

const { t, locale } = Astro.props;

const allLocales: Array<'de' | 'en' | 'es'> = ['de', 'en', 'es'];
const fwRuntime = {
  useCases: t.cases.useCases,
  mock: t.cases.mock,
  voiceTag: t.cases.voiceTag,
};

// Mobile carousel: mini-timber SVG (no clipPath, same geometry as desktop)
const timberSvg = `
<svg viewBox="0 0 300 300">
  <line x1="40"  y1="40"  x2="150" y2="40"  class="beam fw-top-l"/>
  <line x1="150" y1="40"  x2="260" y2="40"  class="beam fw-top-r"/>
  <line x1="260" y1="40"  x2="260" y2="150" class="beam fw-right-t"/>
  <line x1="260" y1="150" x2="260" y2="260" class="beam fw-right-b"/>
  <line x1="150" y1="260" x2="260" y2="260" class="beam fw-bottom-r"/>
  <line x1="40"  y1="260" x2="150" y2="260" class="beam fw-bottom-l"/>
  <line x1="40"  y1="150" x2="40"  y2="260" class="beam fw-left-b"/>
  <line x1="40"  y1="40"  x2="40"  y2="150" class="beam fw-left-t"/>
  <line x1="40" y1="150" x2="260" y2="150" class="beam fw-h"/>
  <line x1="150" y1="40" x2="150" y2="260" class="beam fw-v"/>
  <line x1="40"  y1="150" x2="150" y2="40"  class="brace fw-d1"/>
  <line x1="150" y1="40"  x2="260" y2="150" class="brace fw-d2"/>
  <line x1="40"  y1="150" x2="150" y2="260" class="brace fw-d3"/>
  <line x1="150" y1="260" x2="260" y2="150" class="brace fw-d4"/>
  <g class="pillar-node" data-p="0">
    <circle cx="40" cy="40" r="6" class="node"/>
    <text x="40" y="28" class="node-label" text-anchor="start">${t.platform.pillarLabels.werkstatt}</text>
  </g>
  <g class="pillar-node" data-p="1">
    <circle cx="260" cy="40" r="6" class="node"/>
    <text x="260" y="28" class="node-label" text-anchor="end">${t.platform.pillarLabels.katalog}</text>
  </g>
  <g class="pillar-node" data-p="2">
    <circle cx="150" cy="150" r="9" class="node node-center"/>
  </g>
  <g class="pillar-node" data-p="3">
    <circle cx="40" cy="260" r="6" class="node"/>
    <text x="40" y="282" class="node-label" text-anchor="start">${t.platform.pillarLabels.speicher}</text>
  </g>
  <g class="pillar-node" data-p="4">
    <circle cx="260" cy="260" r="6" class="node"/>
    <text x="260" y="282" class="node-label" text-anchor="end">${t.platform.pillarLabels.wissen}</text>
  </g>
</svg>`;
---
<!DOCTYPE html>
<html lang={locale}>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{t.meta.title}</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&display=swap" rel="stylesheet">
<script is:inline>
window.TWEAKS = {
  "accentHue": 194,
  "gridDensity": 24,
  "dark": false,
  "showGrid": true,
  "useCase": "nordware"
};
</script>
</head>
<body>

<nav class="top">
  <a href={`/${locale}/`} class="nav-logo">
    <svg viewBox="0 0 128 128" aria-label="Fachwerk" xmlns="http://www.w3.org/2000/svg">
      <rect width="128" height="128" fill="#1e2430"/>
      <defs><clipPath id="nav-frame"><rect x="14" y="14" width="100" height="100"/></clipPath></defs>
      <g stroke="#5eead4" stroke-width="7" stroke-linecap="square" fill="none" clip-path="url(#nav-frame)">
        <rect x="16" y="16" width="96" height="96"/>
        <line x1="16" y1="64" x2="112" y2="64"/>
        <line x1="64" y1="16" x2="64" y2="112"/>
        <line x1="16" y1="64" x2="64" y2="16"/>
        <line x1="64" y1="16" x2="112" y2="64"/>
        <line x1="16" y1="64" x2="64" y2="112"/>
        <line x1="64" y1="112" x2="112" y2="64"/>
      </g>
    </svg>
    <span class="wordmark">Fachwerk</span>
    <span class="dot"></span>
  </a>
  <span class="nav-section" id="nav-section" aria-live="polite"></span>
  <div class="nav-links">
    <a href="#problem">{t.nav.problem}</a>
    <a href="#pillars">{t.nav.platform}</a>
    <a href="#cases">{t.nav.examples}</a>
    <a href="#pricing">{t.nav.pricing}</a>
    <a href="#pov" class="nav-cta">{t.nav.contact}</a>
    <span class="lang">{allLocales.map((l, i) => (
      <>
        {i > 0 && <span class="sep"> · </span>}
        {l === locale
          ? <span class="sw on">{l.toUpperCase()}</span>
          : <a href={`/${l}/`} class="sw">{l.toUpperCase()}</a>}
      </>
    ))}</span>
  </div>
</nav>

<div class="content">

<section class="hero">
  <div class="hero-left">
    <div class="hero-eyebrow">
      <span class="eyebrow">{t.hero.eyebrow}</span>
      <span class="hero-meta">{t.hero.meta}</span>
    </div>

    <h1 class="hero-head" set:html={t.hero.headline}></h1>

    <p class="hero-sub" set:html={t.hero.sub}></p>

    <div class="hero-actions">
      <a href="#kontakt" class="btn">{t.hero.ctaPrimary} <span class="arr">→</span></a>
      <a href="#cases" class="btn ghost">{t.hero.ctaSecondary}</a>
    </div>
  </div>

  <div class="hero-right">
    <div class="hr-card">
      <div class="hr-chrome">
        <span id="slide-caption" class="hr-caption">{t.hero.slides[0].caption}</span>
        <div class="dots"><span></span><span></span><span></span></div>
      </div>
      <div class="hr-slides" id="hr-slides">
        {t.hero.slides.map((s, i) => {
          const imgs = SLIDES[s.id as keyof typeof SLIDES];
          return (
            <Image
              class={`hr-slide${i === 0 ? ' active' : ''}`}
              src={imgs.thumb}
              alt={s.alt}
              widths={[800, 1200, 1600]}
              sizes="(min-width: 1100px) 45vw, (min-width: 900px) 90vw, 92vw"
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
              format="webp"
              quality={82}
              data-full={imgs.fullUrl}
              data-caption={s.caption}
            />
          );
        })}
        <button class="hr-fs" id="hr-fs" aria-label={t.a11y.fullscreen}>
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square">
            <path d="M3 7V3h4M17 7V3h-4M3 13v4h4M17 13v4h-4"/>
          </svg>
        </button>
        <div class="hr-dots" id="hr-dots">
          {t.hero.slides.map((_s, i) => (
            <button class={`hr-dot${i === 0 ? ' active' : ''}`} data-i={i} aria-label={`Slide ${i + 1}`}></button>
          ))}
        </div>
      </div>
    </div>
    <div class="hr-lightbox" id="hr-lightbox" aria-hidden="true">
      <button class="hr-lb-close" id="hr-lb-close" aria-label={t.a11y.close}>✕</button>
      <button class="hr-lb-nav prev" id="hr-lb-prev" aria-label={t.a11y.prev}>‹</button>
      <img class="hr-lb-img" id="hr-lb-img" alt="">
      <button class="hr-lb-nav next" id="hr-lb-next" aria-label={t.a11y.next}>›</button>
    </div>

    <div class="hero-bullets">
      {t.hero.bullets.map(b => (
        <div class="hero-bullet"><strong>{b.title}</strong>{b.desc}</div>
      ))}
    </div>
  </div>

  <span class="hero-corner br">{t.hero.scroll}</span>
</section>

<div class="marquee">
  <div class="marquee-track">
    {[0, 1].map(() => (
      <>
        {t.marquee.pillars.map(p => (
          <span><span class="mark">◆</span> {p}</span>
        ))}
        {t.marquee.systems.map(s => (
          <span><span class="mark">✕</span> {s}</span>
        ))}
      </>
    ))}
  </div>
</div>


<section class="block" id="problem">
  <div class="block-head">
    <div>
      <span class="eyebrow">{t.problem.eyebrow}</span>
      <div class="block-index" style="margin-top:1rem">{t.problem.index}</div>
    </div>
    <div>
      <h2 class="block-title" set:html={t.problem.title}></h2>
      <p class="block-lede" set:html={t.problem.lede}></p>
    </div>
  </div>

  <div class="problem-grid">
    {t.problem.cells.map(c => (
      <div class="problem-cell" data-num={c.num}>
        <h4><span class="warn">{c.warn}</span>{c.title}</h4>
        <p>{c.body}</p>
      </div>
    ))}
  </div>
</section>

<section class="block zoo-section cream-section" id="falle">
  <div class="block-head zoo-head">
    <div>
      <span class="eyebrow">{t.zoo.eyebrow}</span>
      <div class="block-index" style="margin-top:1rem">{t.zoo.index}</div>
    </div>
    <div>
      <h2 class="block-title" set:html={t.zoo.title}></h2>
      <p class="block-lede" set:html={t.zoo.lede}></p>
      <div class="zoo-canvas">
        {t.zoo.bad.apps.map((app, i) => (
          <div class={`zoo-app za-${i + 1}`}>
            {app.label}
            {app.tag && <span class="ztag">{app.tag}</span>}
          </div>
        ))}
        {t.zoo.bad.warns.map((w, i) => (
          <div class={i === 0 ? 'zoo-warn' : 'zoo-warn zoo-warn-2'}>{w}</div>
        ))}
      </div>
    </div>
  </div>
</section>

<section class="block dark-section" id="pillars">
  <div class="block-head">
    <div>
      <span class="eyebrow">{t.platform.eyebrow}</span>
      <div class="block-index" style="margin-top:1rem">{t.platform.index}</div>
    </div>
    <div>
      <h2 class="block-title" set:html={t.platform.title}></h2>
      <p class="block-lede" set:html={t.platform.lede}></p>
    </div>
  </div>

  <div class="timber-wrap">
    <div class="timber">
      <span class="timber-label-sys">{t.platform.timberSys1}</span>
      <span class="timber-label-sys2">{t.platform.timberSys2}</span>
      <svg viewBox="0 0 300 300">
        <defs>
          <clipPath id="fwframe"><rect x="36" y="36" width="228" height="228"/></clipPath>
        </defs>
        <line x1="40"  y1="40"  x2="150" y2="40"  class="beam fw-top-l"/>
        <line x1="150" y1="40"  x2="260" y2="40"  class="beam fw-top-r"/>
        <line x1="260" y1="40"  x2="260" y2="150" class="beam fw-right-t"/>
        <line x1="260" y1="150" x2="260" y2="260" class="beam fw-right-b"/>
        <line x1="150" y1="260" x2="260" y2="260" class="beam fw-bottom-r"/>
        <line x1="40"  y1="260" x2="150" y2="260" class="beam fw-bottom-l"/>
        <line x1="40"  y1="150" x2="40"  y2="260" class="beam fw-left-b"/>
        <line x1="40"  y1="40"  x2="40"  y2="150" class="beam fw-left-t"/>
        <line x1="40" y1="150" x2="260" y2="150" class="beam fw-h"/>
        <line x1="150" y1="40" x2="150" y2="260" class="beam fw-v"/>
        <line x1="40"  y1="150" x2="150" y2="40"  class="brace fw-d1"/>
        <line x1="150" y1="40"  x2="260" y2="150" class="brace fw-d2"/>
        <line x1="40"  y1="150" x2="150" y2="260" class="brace fw-d3"/>
        <line x1="150" y1="260" x2="260" y2="150" class="brace fw-d4"/>

        <g class="pillar-node" data-p="0">
          <circle cx="40" cy="40" r="6" class="node"/>
          <text x="40" y="28" class="node-label" text-anchor="start">{t.platform.pillarLabels.werkstatt}</text>
        </g>
        <g class="pillar-node" data-p="1">
          <circle cx="260" cy="40" r="6" class="node"/>
          <text x="260" y="28" class="node-label" text-anchor="end">{t.platform.pillarLabels.katalog}</text>
        </g>
        <g class="pillar-node" data-p="2">
          <circle cx="150" cy="150" r="9" class="node node-center"/>
        </g>
        <g class="pillar-node" data-p="3">
          <circle cx="40" cy="260" r="6" class="node"/>
          <text x="40" y="282" class="node-label" text-anchor="start">{t.platform.pillarLabels.speicher}</text>
        </g>
        <g class="pillar-node" data-p="4">
          <circle cx="260" cy="260" r="6" class="node"/>
          <text x="260" y="282" class="node-label" text-anchor="end">{t.platform.pillarLabels.wissen}</text>
        </g>
      </svg>
    </div>

    <div class="pillars-list" id="pillars-list">
      {t.platform.pillars.map(p => (
        <div class={`pillar${p.active ? ' active' : ''}`} data-p={p.p}>
          <div class="pillar-head">
            <span class="pillar-num">{p.num}</span>
            <h3 class="pillar-name">{p.name}</h3>
            <span class="pillar-tag">{p.tag}</span>
          </div>
          <p>{p.body}</p>
        </div>
      ))}
    </div>
  </div>

  {/* Mobile carousel: one slide = mini-timber (corner highlighted) + pillar copy */}
  <div class="timber-carousel" id="timber-carousel">
    {t.platform.pillars.map((p, i) => (
      <div class="tc-slide" data-i={i} data-p={p.p}>
        <div class={`timber hovering p-${p.p}`} set:html={timberSvg}></div>
        <div class="tc-copy">
          <div class="tc-head">
            <span class="pillar-num">{p.num}</span>
            <h3 class="pillar-name">{p.name}</h3>
          </div>
          <span class="pillar-tag">{p.tag}</span>
          <p>{p.body}</p>
        </div>
      </div>
    ))}
  </div>
  <div class="tc-dots" id="tc-dots">
    {t.platform.pillars.map((p, i) => (
      <button class={`tc-dot${i === 0 ? ' active' : ''}`} data-i={i} aria-label={p.name}></button>
    ))}
  </div>

</section>

<section class="block diagnose-section cream-section" id="diagnose">
  <div class="block-head">
    <div>
      <span class="eyebrow">{t.diagnose.eyebrow}</span>
      <div class="block-index" style="margin-top:1rem">{t.diagnose.index}</div>
    </div>
    <div>
      <h2 class="block-title" set:html={t.diagnose.title}></h2>
      <p class="block-lede" set:html={t.diagnose.lede}></p>
    </div>
  </div>

  <div class="diag-grid">
    {t.diagnose.examples.map(ex => (
      <div class="diag-card">
        <span class="diag-tag">{ex.tag}</span>
        <p class="diag-q">{ex.q}</p>
        <p class="diag-a">{ex.a}</p>
      </div>
    ))}
  </div>

  <p class="diag-closing" set:html={t.diagnose.closing}></p>
</section>

<section class="block ai-section" id="how">
  <div class="block-head">
    <div>
      <span class="eyebrow">{t.ai.eyebrow}</span>
      <div class="block-index" style="margin-top:1rem">{t.ai.index}</div>
    </div>
    <div>
      <h2 class="block-title" set:html={t.ai.title}></h2>
      <p class="block-lede" set:html={t.ai.lede}></p>
    </div>
  </div>

  <div class="compare-table-wrap">
    <span class="compare-table-eyebrow">{t.ai.compareTable.eyebrow}</span>
    <div class="compare-table">
      {t.ai.compareTable.heads.map(h => <div class="compare-head">{h}</div>)}
      {t.ai.compareTable.rows.map(r => (
        <>
          <div class="compare-sys">{r.sys}</div>
          <div class="compare-promise">{r.promise}</div>
          <div class="compare-need">{r.need}</div>
        </>
      ))}
    </div>
  </div>

  <div class="ai-points">
    {t.ai.points.map(p => (
      <div class="ai-point">
        <span class="ai-num">{p.num}</span>
        <h4>{p.title}</h4>
        <p>{p.body}</p>
      </div>
    ))}
  </div>
</section>

<section class="block ki-section cream-section" id="ki">
  <div class="block-head">
    <div>
      <span class="eyebrow">{t.ki.eyebrow}</span>
      <div class="block-index" style="margin-top:1rem">{t.ki.index}</div>
    </div>
    <div>
      <h2 class="block-title" set:html={t.ki.title}></h2>
      <p class="block-lede" set:html={t.ki.lede}></p>
    </div>
  </div>

  <ul class="ki-points">
    {t.ki.points.map(point => (
      <li class="ki-point">
        <span class="ki-point-label">{point.label}</span>
        <p class="ki-point-body">{point.body}</p>
      </li>
    ))}
  </ul>

  <div class="ai-grid">
    <div class="ai-diagram">
      <div class="ai-chrome">{t.ai.flowTitle}</div>
      <div class="ai-flow">
        {t.ai.steps.map((s, i) => (
          <>
            <div class={`ai-step s-${s.type}`}>
              <div class="s-type">{s.type === 'ai' ? 'AI' : 'Code'}</div>
              <div class="s-name">{s.name}</div>
              <div class="s-meta">{s.meta}</div>
            </div>
            {i < t.ai.steps.length - 1 && <div class="ai-arrow"></div>}
          </>
        ))}
      </div>
      <div class="ai-legend">
        <span class="ai-legend-item"><span class="dot dot-code"></span> {t.ai.legend.code}</span>
        <span class="ai-legend-item"><span class="dot dot-ai"></span> {t.ai.legend.ai}</span>
      </div>
    </div>
  </div>
</section>

<section class="block dark-section" id="cases">
  <div class="block-head">
    <div>
      <span class="eyebrow">{t.cases.eyebrow}</span>
      <div class="block-index" style="margin-top:1rem">{t.cases.index}</div>
    </div>
    <div>
      <h2 class="block-title" set:html={t.cases.title}></h2>
      <p class="block-lede" set:html={t.cases.lede}></p>
    </div>
  </div>

  <div class="branch-strip">
    {t.cases.tabs.map((tab) => {
      const ucKey = tab.uc as keyof typeof t.cases.useCases;
      const uc = t.cases.useCases[ucKey];
      return (
        <div class="branch-card">
          <span class="branch-num">{tab.num}</span>
          <h3 class="branch-name">{tab.label}</h3>
          <p class="branch-task">{uc.title}</p>
        </div>
      );
    })}
  </div>
</section>

<section class="block" id="kipp">
  <div class="block-head">
    <div>
      <span class="eyebrow">{t.kipp.eyebrow}</span>
      <div class="block-index" style="margin-top:1rem">{t.kipp.index}</div>
    </div>
    <div>
      <h2 class="block-title" set:html={t.kipp.title}></h2>
      <p class="block-lede" set:html={t.kipp.lede}></p>
    </div>
  </div>

  <div class="fit-table">
    {t.kipp.heads.map(h => <div class="fit-head">{h}</div>)}
    {t.kipp.rows.map(r => (
      <>
        <div class="fit-category">{r.category}</div>
        <div class="fit-cell">{r.good}</div>
        <div class="fit-cell">{r.tip}</div>
      </>
    ))}
  </div>
</section>

<section class="block pov-section cream-section" id="pov">
  <div class="block-head">
    <div>
      <span class="eyebrow">{t.pov.eyebrow}</span>
      <div class="block-index" style="margin-top:1rem">{t.pov.index}</div>
    </div>
    <div>
      <h2 class="block-title" set:html={t.pov.title}></h2>
      <p class="block-lede" set:html={t.pov.lede}></p>
    </div>
  </div>

  <ol class="pov-timeline">
    {t.pov.steps.map(step => (
      <li class="pov-step">
        <span class="pov-day">{step.day}</span>
        <span class="pov-step-title">{step.title}</span>
        <span class="pov-step-desc">{step.desc}</span>
      </li>
    ))}
  </ol>

  <div class="pov-architect">
    <h3 class="pov-architect-name">{t.pov.architect.name}</h3>
    <div class="pov-architect-card">
      <p class="pov-architect-bio" set:html={t.pov.architect.bio}></p>
      <div class="pov-architect-contact">
        <span class="pov-architect-contact-label">{t.pov.architect.contact}</span>
        <a href="mailto:sebastian@s16e.de">sebastian@s16e.de</a>
        <a href="tel:+491724290654">+49 172 4290654</a>
        <a href={t.pov.architect.linkedinHref} target="_blank" rel="noopener">{t.pov.architect.linkedin}</a>
      </div>
    </div>
  </div>
</section>

<section class="block" id="deploy">
  <div class="block-head">
    <div>
      <span class="eyebrow">{t.deploy.eyebrow}</span>
      <div class="block-index" style="margin-top:1rem">{t.deploy.index}</div>
    </div>
    <div>
      <h2 class="block-title" set:html={t.deploy.title}></h2>
    </div>
  </div>

  <div class="deploy-grid">
    <div class="deploy-cell">
      <div class="icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 16 a6 4 0 1 1 0 0 M8 16 h12 a3 3 0 0 0 0-6 a5 5 0 0 0-9-3 a4 4 0 0 0-7 6"/>
        </svg>
      </div>
      <h4>{t.deploy.cells[0].title}</h4>
      <p set:html={t.deploy.cells[0].body}></p>
      <div class="tag-row">{t.deploy.cells[0].tags.map(tag => <span class="tag">{tag}</span>)}</div>
    </div>
    <div class="deploy-cell">
      <div class="icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="5" width="18" height="14"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
          <circle cx="7" cy="7.5" r="0.8" fill="currentColor"/>
        </svg>
      </div>
      <h4>{t.deploy.cells[1].title}</h4>
      <p set:html={t.deploy.cells[1].body}></p>
      <div class="tag-row">{t.deploy.cells[1].tags.map(tag => <span class="tag">{tag}</span>)}</div>
    </div>
    <div class="deploy-cell">
      <div class="icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="8" cy="12" r="4"/>
          <circle cx="16" cy="12" r="4"/>
        </svg>
      </div>
      <h4>{t.deploy.cells[2].title}</h4>
      <p set:html={t.deploy.cells[2].body}></p>
      <div class="tag-row">{t.deploy.cells[2].tags.map(tag => <span class="tag">{tag}</span>)}</div>
    </div>
  </div>
</section>

<section class="block cream-section" id="pricing">
  <div class="block-head">
    <div>
      <span class="eyebrow">{t.pricing.eyebrow}</span>
      <div class="block-index" style="margin-top:1rem">{t.pricing.index}</div>
    </div>
    <div>
      <h2 class="block-title" set:html={t.pricing.title}></h2>
      <p class="block-lede" set:html={t.pricing.lede}></p>
    </div>
  </div>

  <div class="price-grid price-grid-3">
    {t.pricing.tiers.map(pk => (
      <div class="price-card">
        <span class="price-tier">{pk.tier}</span>
        <h3>{pk.h3}</h3>
        <p class="price-desc">{pk.desc}</p>
        <div class="price-num">{pk.num}<span class="unit">{pk.unit}</span></div>
        <div class="price-sub">{pk.sub}</div>
        <ul class="price-list">
          {pk.list.map(li => <li>{li}</li>)}
        </ul>
      </div>
    ))}
  </div>

  <div class="price-addons">
    {t.pricing.addons.map(addon => (
      <div class="price-addon">
        <span class="price-tier">{addon.tier}</span>
        <h3>{addon.h3}</h3>
        <p class="price-desc">{addon.desc}</p>
      </div>
    ))}
  </div>

</section>

<section class="cta" id="kontakt">
  <div class="cta-inner">
    <span class="eyebrow">{t.cta.eyebrow}</span>
    <h2 set:html={t.cta.title}></h2>
    <p>{t.cta.body}</p>

    <div class="cta-row">
      <a href="mailto:sebastian@s16e.de" class="btn">{t.cta.emailLabel} <span class="arr">→</span></a>
      <a href="tel:+491724290654" class="btn ghost">{t.cta.phoneLabel}</a>
      <a href="https://www.linkedin.com/in/sebastian-breitzke/" class="btn ghost">{t.cta.linkedinLabel}</a>
    </div>
  </div>
</section>

<footer>
  <div class="finner">
    <span class="fleft"><strong>s16e</strong> · Sebastian Breitzke · <a href="https://s16e.de">s16e.de</a></span>
    <span class="fright">
      <a href={t.footer.impressumHref}>{t.footer.impressum}</a>
      <a href={t.footer.datenschutzHref}>{t.footer.datenschutz}</a>
      {allLocales.map((l, i) => (
        <>
          {i > 0 && <span> · </span>}
          {l === locale
            ? <span class="on">{l.toUpperCase()}</span>
            : <a href={`/${l}/`}>{l.toUpperCase()}</a>}
        </>
      ))}
    </span>
  </div>
</footer>

</div>

<script is:inline set:html={`window.FW_HOME = ${JSON.stringify(fwRuntime)};`}></script>
<script is:inline src="/fw-home.js"></script>

</body>
</html>
