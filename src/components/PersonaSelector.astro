---
interface Props {
  label: string;
  techie: string;
  fachlich: string;
  business: string;
  hint?: string;
}
const { label, techie, fachlich, business, hint } = Astro.props;
---
<div class="persona-strip" role="group" aria-label={label}>
  <span class="persona-strip-label">{label}</span>
  <div class="persona-pills">
    <button class="persona-pill" data-set-persona="techie" type="button" aria-pressed="false">{techie}</button>
    <button class="persona-pill" data-set-persona="fachlich" type="button" aria-pressed="false">{fachlich}</button>
    <button class="persona-pill" data-set-persona="business" type="button" aria-pressed="false">{business}</button>
  </div>
  {hint && <span class="persona-strip-hint">{hint}</span>}
</div>

<script is:inline>
  (function () {
    const root = document.documentElement;
    const pills = document.querySelectorAll('.persona-pill[data-set-persona]');
    function sync() {
      const p = root.dataset.persona || 'fachlich';
      pills.forEach(btn => {
        const match = btn.dataset.setPersona === p;
        btn.classList.toggle('active', match);
        btn.setAttribute('aria-pressed', String(match));
      });
    }
    pills.forEach(btn => {
      btn.addEventListener('click', () => {
        const p = btn.dataset.setPersona;
        try { localStorage.setItem('fw-persona', p); } catch (e) {}
        root.dataset.persona = p;
        sync();
      });
    });
    sync();
  })();
</script>
